# 文件存储根目录（单目录模式，相对于 backend/ 目录）
UPLOAD_DIR=uploads

# 多根目录配置（可选，格式：JSON 字符串）
# 支持两种格式：
# 1. 列表格式（自动生成别名）：["/path/root1", "/path/root2"]
#    别名将自动生成为: root0, root1, root2...
# 2. 字典格式（自定义别名）：{"default": "/path/root1", "work": "/path/root2", "默认": "/opt/uploads"}
#    别名可以是任意字符串（推荐英文，但中文也支持）
# 如果设置了 UPLOAD_DIRS，则优先使用此配置，忽略 UPLOAD_DIR
# 示例配置（按需取消注释并修改）：
# UPLOAD_DIRS=["/opt/uploads", "/home/user/workspace"]
# 或使用自定义别名：
# UPLOAD_DIRS={"default": "/opt/uploads", "openclaw": "/home/user/.openclaw/workspace", "默认": "/opt/uploads"}
UPLOAD_DIRS=[]

# 最大上传文件大小（字节，默认 100MB）
MAX_FILE_SIZE=104857600

# 预览最大文件大小（字节，默认 5MB）
PREVIEW_MAX_SIZE=5242880

# CORS 允许的源（生产环境应设置为具体前端域名）
# 示例：ALLOWED_ORIGINS=["http://localhost:5173","https://yourdomain.com"]
ALLOWED_ORIGINS=["*"]
